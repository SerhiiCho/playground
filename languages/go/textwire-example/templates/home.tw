@use('layouts/base')

@insert('title', 'Book Store')

@insert('content')
    <h1 class="text-2xl font-bold">Welcome to the Book Store</h1>
    <p class="opacity-70 mb-5">See the list of our books</p>

    @if(books.len() > 0)
        <div>
            @each(book in books)
                @component('components/book', { book })
            @end
        </div>
    @else
        <p>No books found</p>
    @end
@end